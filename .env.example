# OpenCare : exemple de configuration (developpement / Docker local)
# Copiez ce fichier en .env a la racine du projet, puis ajustez les valeurs.

# --- Base de donnees PostgreSQL ---
# Avec docker-compose, POSTGRES_PORT pilote aussi le port expose sur l'hote.
# 5433 par defaut ici pour eviter tout conflit avec un PostgreSQL deja installe.
# Le schema s'installe tout seul au premier demarrage du serveur.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=opencare
POSTGRES_USER=opencare
POSTGRES_PASSWORD=opencare2024

# --- Serveur ---
SERVER_PORT=3001
NODE_ENV=development

# Secret JWT : 32 caracteres minimum, le serveur refuse les valeurs d'exemple.
# Generez-en un : openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret

# Cle dediee de chiffrement des credentials d'integration (optionnelle en dev:
# si absente, derivee du JWT_SECRET). Recommandee en production. openssl rand -hex 32
# INTEGRATIONS_ENCRYPTION_KEY=

# Rate limiting sur /api/auth/login et /api/auth/register (anti brute-force) :
# fenetre en millisecondes et nombre maximal de tentatives echouees.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Origines autorisees pour le CORS (separees par des virgules).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Mettre a false pour bloquer la creation de nouveaux comptes
# (une fois tous les membres du cercle inscrits).
REGISTRATION_ENABLED=true

# --- Client (variables de build Vite) ---
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# --- Notifications Web Push (optionnel) ---
# Generez les cles avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:votre-email@exemple.fr

# --- Options avancees (decommentez au besoin) ---

# Niveau de logs du serveur : debug, info, warn, error.
# LOG_LEVEL=info

# Fuseau horaire des planificateurs (rappels, synthese hebdo, veille passive).
# TZ=Europe/Paris

# Si defini, le serveur Express sert aussi le client construit depuis ce dossier
# (meme origine pour l'API et l'interface, utilise par l'installateur Windows).
# SERVE_CLIENT_DIR=../client/dist

# Durcissement : bloquer les IP privees (loopback, RFC1918...) comme cibles
# des integrations. A laisser desactive si Home Assistant, Immich, Whisper ou
# Grocy tournent sur votre reseau local.
# INTEGRATIONS_BLOCK_PRIVATE_IPS=true
