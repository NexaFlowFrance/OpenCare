# OpenCare : exemple de configuration de production
# Copiez ce fichier en .env sur votre hote de production et changez CHAQUE valeur.
# Rappel : OpenCare stocke des donnees de sante. Secrets forts, HTTPS, CORS strict.

# --- Base de donnees (reseau interne Docker Compose) ---
# Le serveur refuse de demarrer en production sans POSTGRES_PASSWORD.
# Le schema s'installe tout seul au premier demarrage du serveur.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opencare
POSTGRES_USER=opencare
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Serveur ---
SERVER_PORT=3001
NODE_ENV=production

# Secret JWT : 32 caracteres minimum, le serveur refuse les valeurs d'exemple.
# Generez-en un : openssl rand -hex 32
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Cle de chiffrement des credentials d'integration (cles API, mots de passe
# Nextcloud/HA...), chiffres au repos en AES-256-GCM. Recommandee en production,
# DISTINCTE du JWT_SECRET (separation des usages). Generez : openssl rand -hex 32
# Si absente, la cle est derivee du JWT_SECRET (compatible, mais moins cloisonne).
INTEGRATIONS_ENCRYPTION_KEY=CHANGE_ME_DEDICATED_ENCRYPTION_KEY_HEX_32

# Rate limiting sur l'authentification (anti brute-force).
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Inscription publique FERMEE par defaut (securise par defaut). Les personnes
# invitees peuvent toujours creer leur compte via leur lien d'invitation, et le
# tout premier compte (administrateur) peut etre cree meme inscription fermee.
# Passez a 'true' uniquement si vous voulez autoriser l'inscription libre.
REGISTRATION_ENABLED=false

# --- URL publiques ---
# Variables de build du client (Vite) et origines CORS autorisees.
VITE_API_URL=https://api.votre-domaine.tld
VITE_WS_URL=wss://api.votre-domaine.tld
CORS_ORIGINS=https://app.votre-domaine.tld

# --- Notifications Web Push (optionnel, HTTPS requis) ---
# Generez les cles avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@votre-domaine.tld

# --- Options avancees (decommentez au besoin) ---

# Niveau de logs du serveur : debug, info, warn, error.
# LOG_LEVEL=info

# Fuseau horaire des planificateurs (rappels, synthese hebdo, veille passive).
# TZ=Europe/Paris

# Durcissement : bloquer les IP privees comme cibles des integrations.
# A laisser desactive si vos services (Home Assistant, Immich, Whisper, Grocy)
# tournent sur le meme reseau prive que le serveur.
# INTEGRATIONS_BLOCK_PRIVATE_IPS=true
